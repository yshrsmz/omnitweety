{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    // "composite": true,
    // "allowSyntheticDefaultImports": true,
    // "resolveJsonModule": true

    "types": ["@types/node"]
  },
  "include": [
    "wxt.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "package.json",
    "apikey-release.json"
  ]
}
